{
  "id": "02-where-range-operators",
  "title": "`where` range operators ($gte, $lte) silently ignored on list endpoints",
  "hypothesis": "A `where` clause with $gte set to a far-future date should return zero records. Instead the API returns the same record count as an unfiltered call.",
  "verdict": "CONFIRMED_BUG",
  "summary": "Future-date $gte filter returned 100 rows (meta.total=5724); unfiltered returned 100 rows (meta.total=5724). Filter ignored.",
  "evidence": {
    "endpoint": "GET /v3/order",
    "baseline": {
      "query": {
        "limit": 100
      },
      "dataLength": 100,
      "metaTotal": 5724
    },
    "filtered": {
      "query": {
        "limit": 100,
        "where": {
          "createdDate": {
            "$gte": "2099-01-01T00:00:00Z"
          }
        }
      },
      "dataLength": 100,
      "metaTotal": 5724
    }
  },
  "requests": [
    {
      "method": "GET",
      "path": "/order",
      "query": {
        "limit": "100"
      },
      "status": 200,
      "durationMs": 282,
      "responseSummary": {
        "dataLength": 100,
        "metaTotal": 5724,
        "metaHasMore": true
      }
    },
    {
      "method": "GET",
      "path": "/order",
      "query": {
        "limit": "100",
        "where": "{\"createdDate\":{\"$gte\":\"2099-01-01T00:00:00Z\"}}"
      },
      "status": 200,
      "durationMs": 280,
      "responseSummary": {
        "dataLength": 100,
        "metaTotal": 5724,
        "metaHasMore": true
      }
    }
  ],
  "capturedAt": "2026-04-27T21:37:28.243Z"
