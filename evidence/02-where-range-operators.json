{
  "id": "02-where-range-operators",
  "title": "`where` range operators ($gte, $lte) silently ignored on list endpoints",
  "hypothesis": "A `where` clause with $gte set to a far-future date should return zero records. Instead the API returns the same record count as an unfiltered call.",
  "verdict": "CONFIRMED_BUG",
  "summary": "Future-date $gte filter returned 100 rows (meta.total=5720); unfiltered returned 100 rows (meta.total=5720). Filter ignored.",
  "evidence": {
    "endpoint": "GET /v3/order",
    "baseline": {
      "query": {
        "limit": 100
      },
      "dataLength": 100,
      "metaTotal": 5720
    },
    "filtered": {
      "query": {
        "limit": 100,
        "where": {
          "createdDate": {
            "$gte": "2099-01-01T00:00:00Z"
          }
        }
      },
      "dataLength": 100,
      "metaTotal": 5720
    }
  },
  "requests": [
    {
      "method": "GET",
      "path": "/order",
      "query": {
        "limit": "100"
      },
      "status": 200,
      "durationMs": 275,
      "responseSummary": {
        "dataLength": 100,
        "metaTotal": 5720,
        "metaHasMore": true
      }
    },
    {
      "method": "GET",
      "path": "/order",
      "query": {
        "limit": "100",
        "where": "{\"createdDate\":{\"$gte\":\"2099-01-01T00:00:00Z\"}}"
      },
      "status": 200,
      "durationMs": 258,
      "responseSummary": {
        "dataLength": 100,
        "metaTotal": 5720,
        "metaHasMore": true
      }
    }
  ],
  "capturedAt": "2026-04-27T20:57:48.766Z"
}